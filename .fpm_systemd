-s dir
--name inhive-core
--category net
--license GPL-3.0-or-later
--description "The universal proxy platform."
--url "https://inhive.ru/"
--maintainer "inhive <core@inhive.ru>"
--deb-field "Bug: https://github.com/twilgate/inhive-core/issues"
--no-deb-generate-changes
--config-files /etc/inhive-core/config.json
--after-install release/config/inhive-core.postinst

release/config/config.json=/etc/inhive-core/config.json

release/config/inhive-core.service=/usr/lib/systemd/system/inhive-core.service
release/config/inhive-core@.service=/usr/lib/systemd/system/inhive-core@.service
release/config/inhive-core.sysusers=/usr/lib/sysusers.d/inhive-core.conf
release/config/inhive-core.rules=usr/share/polkit-1/rules.d/inhive-core.rules
release/config/inhive-core-split-dns.xml=/usr/share/dbus-1/system.d/inhive-core-split-dns.conf

LICENSE.md=/usr/share/licenses/inhive-core/LICENSE.md